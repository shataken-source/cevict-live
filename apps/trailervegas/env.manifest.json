{
  "app": "trailervegas",
  "outputs": [
    {
      "file": ".env.local",
      "vars": {
        "NEXT_PUBLIC_SUPABASE_URL": {
          "from": "NEXT_PUBLIC_SUPABASE_URL",
          "required": true
        },
        "SUPABASE_SERVICE_ROLE_KEY": {
          "from": "SUPABASE_SERVICE_ROLE_KEY",
          "required": true
        },
        "STRIPE_SECRET_KEY": {
          "from": "STRIPE_SECRET_KEY",
          "required": true
        },
        "STRIPE_WEBHOOK_SECRET": {
          "from": "STRIPE_WEBHOOK_SECRET",
          "required": true
        }
      }
    }
  ]
}
