{
  "crons": [
    {
      "path": "/api/cron/track-odds",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/daily-results",
      "schedule": "0 12 * * *"
    },
    {
      "path": "/api/cron/daily-results-retry",
      "schedule": "15 13 * * *"
    },
    {
      "path": "/api/cron/daily-predictions?earlyLines=1",
      "schedule": "0 13 * * *"
    },
    {
      "path": "/api/cron/daily-predictions",
      "schedule": "30 13 * * *"
    },
    {
      "path": "/api/cron/daily-kalshi",
      "schedule": "15 14 * * *"
    },
    {
      "path": "/api/cron/kalshi-settle",
      "schedule": "0 10,15 * * *"
    },
    {
      "path": "/api/progno/weekly-learning",
      "schedule": "0 2 * * 1"
    }
  ],
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "installCommand": "npm install --legacy-peer-deps",
  "ignoreCommand": "git fetch origin $VERCEL_GIT_PREVIOUS_SHA --depth=1 2>/dev/null; git diff --quiet $VERCEL_GIT_PREVIOUS_SHA $VERCEL_GIT_COMMIT_SHA -- apps/progno/ 2>/dev/null || exit 1",
  "outputDirectory": ".next"
}
