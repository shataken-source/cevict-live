{
  "crons": [
    {
      "path": "/api/cron/track-odds",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/daily-predictions",
      "schedule": "30 13 * * *"
    },
    {
      "path": "/api/cron/daily-results",
      "schedule": "0 12 * * *"
    }
  ],
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "installCommand": "npm install --legacy-peer-deps",
  "outputDirectory": ".next"
}
